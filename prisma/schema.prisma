generator client {
  provider             = "prisma-client-py"
  previewFeatures      = ["postgresqlExtensions"]
  recursive_type_depth = 5
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Policy {
  id          Int       @id @default(autoincrement())
  category    String
  article_num String
  content     String
  embedding   Unsupported("vector(768)")
  form_url    String?
  created_at  DateTime  @default(now())
}